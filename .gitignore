# ===========================
# Policy Probe — Root .gitignore
# ===========================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Environment Variables (CRITICAL — NEVER COMMIT) ----
.env
.env.*
!.env.example

# ---- IDE & Editor ----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Build Outputs ----
dist/
build/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# ---- Testing ----
coverage/

# ---- Debug Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Vercel ----
.vercel

# ---- OS Files ----
.DS_Store
*.pem

# ---- Archives (large files) ----
*.zip
*.tar.gz
*.rar

# ---- Misc ----
.gemini/
.agents/
AGENTS.md
CLAUDE.md
